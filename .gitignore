# ============================================================
#  Data — NEVER commit (multi-GB, and the papers are copyrighted).
#  Each machine downloads these locally; see PROJECT_MAP.md.
# ============================================================
data/raw/
data/processed/
papers/
/analysis/                       # top-level scratch analysis dir ONLY (NOT src/analysis/ — the code package)
results/figures/*.png            # loose battery figures regenerate; analysis figures in subdirs ARE kept
*.rds
*.rds.gz
*.mat
*.mtx
*.npz
*.npy
*.h5ad
*.zip

# large per-cell outputs (regenerable by the pipeline; keep the repo lean — only the
# small donor-level / per-gene summary tables and the report PDFs are committed):
results/tables/**/coordinates.csv
results/tables/coordinates_*.csv
results/tables/classifier_entropy.csv

# keep the small committed bits inside the ignored trees:
!data/README.md
!results/figures/
!results/tables/
!results/tables/.gitkeep

# ---- scratch / local / IDE ----
_archive_DELETE_ME/
.idea/
__pycache__/
*.pyc
*.tmp
.~lock*#

# ---- node deps (regenerable; never commit) ----
node_modules/
.Rhistory

# ---- LaTeX build artifacts (disposable; keep .tex + .pdf) ----
*.aux
*.log
*.out
*.toc
*.dvi
*.synctex.gz

# ============================================================
#  KEPT in the repo: all code (src/**: *.py, *.R, *.js),
#  the signatures (signatures/*.txt + README.md),
#  docs/ (primer PDF, deck, email, html source),
#  results/tables/ small CSVs + .gitkeep, data/README.md,
#  PROJECT_MAP.md, src/CODING_PLAN.md, src/README.md.
#  NOTE: results/figures/*.png are NOT committed (regenerated by the pipeline).
# ============================================================

# ---- deck build scratch ----
presentation/qa/
reports/deck/qa/
~$*
*.html.tmp
reports/*.html
