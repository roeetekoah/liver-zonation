\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}H1 --- does zonation erode as disease advances?}{12}{subsection.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}H2 --- which gene programs collapse, and where on the axis?}{12}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces What H1 should look like (illustrative). Zonation is a \textbf  {continuum}, so the healthy coordinate is a \emph  {single wide hump} (cells occupy every position along the axis) --- \emph  {not} two peaks. The signal of healthy zonation is the \textbf  {width} (and that markers track the axis, Fig.\nobreakspace  {}\ref  {fig:scatter}), not bumpiness. As disease advances the hump \textbf  {narrows} toward the middle: cells stop committing to either end. H1 measures that narrowing (coordinate spread/variance) plus the weakening pericentral--periportal anti-correlation --- one number per donor, tested across stages.\relax }}{13}{figure.caption.10}\protected@file@percent }
\newlabel{fig:ridgeline}{{4}{13}{What H1 should look like (illustrative). Zonation is a \textbf {continuum}, so the healthy coordinate is a \emph {single wide hump} (cells occupy every position along the axis) --- \emph {not} two peaks. The signal of healthy zonation is the \textbf {width} (and that markers track the axis, Fig.~\ref {fig:scatter}), not bumpiness. As disease advances the hump \textbf {narrows} toward the middle: cells stop committing to either end. H1 measures that narrowing (coordinate spread/variance) plus the weakening pericentral--periportal anti-correlation --- one number per donor, tested across stages.\relax }{figure.caption.10}{}}
